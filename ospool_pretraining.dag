SUBMIT-DESCRIPTION ospool_pretrain.sub {
	universe = container
	container_image = osdf:///ospool/ap40/data/ian.ross/metl_global_fixed_time_2025-10-10.sif

	request_disk = 100GB
	request_memory = 80000
    retry_request_memory = 120000
	request_cpus = 4
    require_gpus = GlobalMemoryMb >= 32000
    request_gpus = 1 + (GPUs_GlobalMemoryMB < 64000) ?: 0
	gpus_minimum_capability = 7.5
	gpus_maximum_capability = 8.99

	environment = "WANDB_API_KEY=c138f48f6e4bb65c5fb3a4641d9e4be6981686df"

	+is_resumable = true
	+JobDurationCategory = "Long"
	+ProjectName = "PATh_MLSupplement"

	executable = /bin/bash
	transfer_executable = false
	arguments = pretrain.sh $(epoch) $(run_uuid) $(random_seed)

	preserve_relative_paths = true
	transfer_input_files = pretrain.sh, osdf:///ospool/ap40/data/ian.ross/processed-global.tar.gz
	if defined continue_from_checkpoint
	    transfer_input_files = $(transfer_input_files), output/training_logs/$(run_uuid)
	endif
	transfer_output_files = output
	should_transfer_files = YES
	when_to_transfer_output = ON_EXIT_OR_EVICT

	output = $(run_uuid)/$(epoch)_$(CLUSTERID).out
	error = $(run_uuid)/$(epoch)_$(CLUSTERID).err
	stream_output = true
	stream_error = true
	log = metl.log
    priority = $(epoch)

	queue
}

